{
  "name": "@angelcube/rainwall",
  "version": "0.1.0-alpha.stardance",
  "license": "GPL-3.0-only",
  "exports": {
    "./analyze": "./analyze/index.ts",
    "./apply": "./apply/index.ts"
  },
  "tasks": {
    "compile-analyze": "deno compile --output build/rainwall-analyze -A analyze/index.ts",
    "compile-apply": "deno compile --output build/rainwall-apply -A apply/index.ts",
    "analyze": "deno -A analyze/index.ts",
    "apply": "deno -A apply/index.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@^1.1.5"
  },
  "fmt": {
    "semiColons": false,
    "indentWidth": 4,
    "useTabs": true,
    "lineWidth": 120
  }
}
